# Required. Use a Yandex Cloud IAM token accepted by DataLens Public API.
DATALENS_TOKEN=

# Required. Organization ID from DataLens service settings.
DATALENS_ORG_ID=

# Public API base URL and version from the official docs.
DATALENS_API_BASE=https://api.datalens.tech
DATALENS_API_VERSION=1
DATALENS_AUTH_SCHEME=Bearer

# Optional. Used by helper tools when a workbook/collection is not passed explicitly.
DATALENS_DEFAULT_WORKBOOK_ID=
DATALENS_DEFAULT_COLLECTION_ID=

# MCP server bind settings for streamable HTTP.
MCP_HOST=0.0.0.0
MCP_PORT=8000
