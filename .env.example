# Required. Use an OAuth/IAM token accepted by DataLens Public API.
DATALENS_TOKEN=

# Public API base URL. Override if Yandex changes the endpoint or you use another region.
DATALENS_API_BASE=https://datalens.yandex.cloud/api
DATALENS_AUTH_SCHEME=Bearer

# Endpoint paths relative to DATALENS_API_BASE.
DATALENS_HEALTH_PATH=
DATALENS_ENTRIES_PATH=entries
DATALENS_DASHBOARDS_PATH=dashboards

# Optional. Used by helper tools when a workbook/collection is not passed explicitly.
DATALENS_DEFAULT_WORKBOOK_ID=
DATALENS_DEFAULT_COLLECTION_ID=

# MCP server bind settings for streamable HTTP.
MCP_HOST=0.0.0.0
MCP_PORT=8000
